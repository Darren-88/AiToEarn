{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext", // 关键修改：ESNext → NodeNext
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": false,
    "noImplicitAny": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "typeRoots": ["./node_modules/@types"],
    "types": ["node"],
    "baseUrl": "./",
    "paths": {
      "@@/*": ["./commont/*"],
      "@/*": ["./*"],
      "src/*": ["./src/*"]
    },
    "noEmitOnError": false,
    "allowJs": true,
    "checkJs": false
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "server/**/*"
  ]
}
