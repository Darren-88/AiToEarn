{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext", // 解决 import.meta 报错
    "moduleResolution": "NodeNext", // 适配 ESNext 模块
    "outDir": "./dist",
    "rootDir": "./",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": false,
    "noImplicitAny": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "typeRoots": ["./node_modules/@types"],
    "types": [], // 不加载任何类型声明
    "paths": {
      "@@/*": ["./commont/*"], // 配置 @@ 别名
      "@/*": ["./*"] // 配置 @ 别名
    },
    "noEmitOnError": false, // 即使有错误也生成 JS 文件
    "allowJs": true,
    "checkJs": false
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "**/*.test.ts", "dist"]
}
