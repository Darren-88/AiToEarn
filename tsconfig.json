{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS", // 回退到 CommonJS，避开扩展名要求
    "moduleResolution": "Node", // 配套 Node 解析模式
    "outDir": "./dist",
    "rootDir": "./",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": false,
    "noImplicitAny": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "typeRoots": ["./node_modules/@types"],
    "types": ["node"],
    "baseUrl": "./",
    "paths": {
      "@@/*": ["./commont/*"],
      "@/*": ["./*"],
      "src/*": ["./src/*"]
    },
    "noEmitOnError": false, // 即使有少量错误也生成 JS
    "allowJs": true,
    "checkJs": false,
    "allowImportingTsExtensions": true, // 允许导入 .ts 扩展名
    "resolvePackageJsonExports": false,
    "resolvePackageJsonImports": false
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "server/**/*"
  ]
}
