{
  "name": "aitoearn-desktop",
  "version": "1.0.0",
  "description": "AiToEarn Desktop Application",
  "author": "Darren",
  "main": "electron/main/index.ts",
  "scripts": {
    "dev": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build": "npm run rebuild",
    "dist:nsis": "npm run build && electron-builder --win nsis",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.yikart.aitoearn",
    "productName": "AiToEarn",
    "directories": {
      "output": "dist/installer",
      "app": "./"
    },
    "files": [
      "**/*",
      "!node_modules/**/*.ts",
      "!node_modules/**/*.map",
      "!node_modules/**/.bin",
      "!node_modules/**/test",
      "!node_modules/**/docs",
      "!.github/**/*",
      "!server/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "extraResources": [
      {
        "from": "node_modules/better-sqlite3/build/Release",
        "to": "resources/better-sqlite3",
        "filter": ["*.node"]
      }
    ]
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "electron-log": "^5.1.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "node-cache": "^5.1.2",
    "node-schedule": "^2.1.1",
    "p-queue": "^8.0.1",
    "qs": "^6.12.0",
    "reflect-metadata": "^0.2.1",
    "sharp": "^0.33.2",
    "typeorm": "^0.3.20",
    "xml2js": "^0.6.2",
    "@electron-uikit/core": "^1.0.0",
    "@electron-uikit/contextmenu": "^1.0.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "fluent-ffmpeg": "^2.1.2",
    "image-size": "^1.1.1"
  },
  "devDependencies": {
    "electron": "^28.2.8",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "node-gyp": "^10.0.1",
    "typescript": "^5.3.3",
    "@types/node": "^20.11.16"
  }
}
